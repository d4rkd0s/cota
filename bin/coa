#!/usr/bin/env bash
# coa — COTA (Claude on the Air) station control (no AI required at runtime)
#   coa setup          interactive wizard: detect hardware, write station.conf
#   coa selftest       offline decode-chain sanity check (no radio needed)
#   coa doctor         non-interactive preflight diagnostics, fix-hints
#   coa start          preflight + RX loop + dashboard (receive only)
#   coa chase N        work N QSOs (attended! you are the control operator)
#   coa stop           stop everything, force PTT release
#   coa status         one-screen station status
#   coa report         compact session report (QSOs, attempts, per-band)
#   coa logsync        upload new QSOs to QRZ Logbook (idempotent, cron-able)
set -u
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN="$ROOT/bin"

# setup/selftest/doctor/report/logsync must work BEFORE station.conf exists
# (setup creates it) or without touching CAT/audio (these are read-only or
# fully offline) — handle them before sourcing station.conf.
case "${1:-status}" in
  setup)    exec python3 "$BIN/setup.py" "${@:2}";;
  selftest) exec python3 "$BIN/selftest.py" "${@:2}";;
  doctor)   exec python3 "$BIN/doctor.py" "${@:2}";;
  report)   exec python3 "$BIN/report.py" "${@:2}";;
  logsync)  exec bash "$BIN/log-sync.sh" "${@:2}";;
esac

CONF="$ROOT/station.conf"
if [ ! -f "$CONF" ]; then
    echo "no station.conf found — run 'coa setup' first (or: cp station.conf.example station.conf)" >&2
    exit 1
fi
. "$CONF"
DATA="$ROOT/data"
RIG="rigctl -m $RIG_MODEL -r $CAT_PORT -s $CAT_BAUD"

unkey() { $RIG T 0 >/dev/null 2>&1; }

preflight() {
    local fail=0
    [ -e "$CAT_PORT" ] && echo "  OK   CAT port" || { echo "  FAIL CAT port missing ($CAT_PORT)"; fail=1; }
    pactl list short sources | grep -q "${PA_SOURCE%%.*}" && echo "  OK   audio source" || { echo "  FAIL audio source missing"; fail=1; }
    timedatectl show -p NTPSynchronized --value 2>/dev/null | grep -q yes \
        && echo "  OK   clock synced" || echo "  WARN clock not NTP-synced (FT8 needs <1 s!)"
    amixer -D hw:CARD=$ALSA_CARD sset 'Auto Gain Control' off >/dev/null 2>&1
    amixer -D hw:CARD=$ALSA_CARD sset 'Mic' $MIXER_MIC cap    >/dev/null 2>&1
    amixer -D hw:CARD=$ALSA_CARD sset 'Speaker' $MIXER_SPEAKER >/dev/null 2>&1
    echo "  OK   mixer calibration applied"
    if [ "$fail" -eq 0 ] && ! pgrep -f "$BIN/qso.py" >/dev/null; then
        F=$($RIG f 2>/dev/null)
        [ "$F" = "$DIAL_HZ" ] && echo "  OK   radio on $F Hz" || echo "  WARN dial reads '${F:-no answer}', expected $DIAL_HZ"
    fi
    return $fail
}

case "${1:-status}" in
  start)
    echo "=== COTA preflight ==="; preflight || exit 1
    mkdir -p "$DATA"
    pgrep -f "$BIN/dashboard.py" >/dev/null || { nohup python3 "$BIN/dashboard.py" >>"$DATA/dashboard.log" 2>&1 & echo "dashboard: http://localhost:$HTTP_PORT"; }
    pgrep -f "$BIN/rx-loop.sh"   >/dev/null || { nohup bash "$BIN/rx-loop.sh"      >>"$DATA/rx-loop.log"   2>&1 & echo "rx-loop started (receive only)"; }
    ;;
  chase)
    N="${2:?usage: coa chase N  (N QSOs)  |  coa chase Nm  (N minutes)}"
    echo "You are the control operator. Stay at the station. Ctrl-C stops and unkeys."
    "$0" start || exit 1
    trap 'unkey; echo; echo "stopped — PTT: $($RIG t)"' INT TERM
    case "$N" in
      *m) python3 "$BIN/qso.py" --minutes "${N%m}";;
      *)  python3 "$BIN/qso.py" --max-qsos "$N";;
    esac
    unkey
    ;;
  stop)
    pkill -f "$BIN/qso.py"      && echo "chaser stopped"
    pkill -f "$BIN/rx-loop.sh"  && echo "rx-loop stopped"
    pkill -f "$BIN/dashboard.py" && echo "dashboard stopped"
    unkey; echo "PTT: $($RIG t 2>/dev/null || echo '?') (0 = safe)"
    ;;
  status)
    echo "chaser:    $(pgrep -f "$BIN/qso.py" >/dev/null && echo RUNNING || echo idle)"
    echo "rx-loop:   $(pgrep -f "$BIN/rx-loop.sh" >/dev/null && echo RUNNING || echo stopped)"
    echo "dashboard: $(pgrep -f "$BIN/dashboard.py" >/dev/null && echo "http://localhost:$HTTP_PORT" || echo stopped)"
    pgrep -f "$BIN/qso.py" >/dev/null || echo "dial:      $($RIG f 2>/dev/null || echo 'no answer') Hz · PTT $($RIG t 2>/dev/null || echo '?')"
    [ -f "$DATA/qso-attempts.jsonl" ] && echo "QSOs logged: $(wc -l < "$DATA/qso-attempts.jsonl")"
    ;;
  *) echo "usage: coa {setup|selftest|doctor|start|chase N|stop|status|report|logsync}"; exit 1;;
esac
