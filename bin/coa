#!/usr/bin/env bash
# coa -- back-compat alias for bin/seeq (project renamed COTA -> SeeQ 2026-07-23).
# Kept so old muscle memory / scripts / cron entries don't break. New docs and
# examples use `seeq`; this just execs straight through with the same args.
exec "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/seeq" "$@"
