# SeeQ — station configuration (shell-style, read by bash and python)
#
#   cp station.conf.example station.conf   # then edit EVERY value for YOUR station
#
# station.conf is gitignored — your personal settings never leave this machine.
# You are the control operator: FCC Part 97 (or your country's rules) requires an
# attending licensed operator responsible for every transmission.

MODE=ft8                        # default/label mode for 'seeq setup' -- NOT a runtime auto-select:
                                 # the dashboard always boots to a mode chooser (docs/MODES-ROADMAP.md)
MYCALL=N0CALL                   # YOUR callsign (N0CALL will not decode — change it!)
LICENSE_CLASS=general            # drives bin/band_plan.py's strict FCC compliance gate
                                 # (blocks seeq start/chase on out-of-privilege freq/power).
                                 # only "general" is supported today -- extend band_plan.py
                                 # before setting anything else.
MYGRID=AA00                     # first 4 chars of YOUR Maidenhead locator (AA00aa -> AA00); FT8 messages carry 4
DIAL_HZ=14074000                # FT8 watering hole, Hz (40 m = 7074000, 20 m = 14074000)
BAND=20m                        # must match DIAL_HZ; used for ADIF logging + display
TX_PWR=5                        # watts — update when you change your rig's power setting!

# CAT (Hamlib): stable serial path + rig model number.
#   ls /dev/serial/by-id/          -> pick YOUR adapter's stable path
#   rigctl --list | grep -i <rig>  -> find YOUR rig's model number
# Example below: Xiegu G90 via its FTDI cable, driven as model 3060 (IC-7000
# CI-V dialect — works on older Hamlib; Hamlib >= 4.5 has a native G90 model).
CAT_PORT=/dev/serial/by-id/usb-FTDI_USB__-__Serial-if00-port0
RIG_MODEL=3060
CAT_BAUD=19200

# Audio (PulseAudio names — 'pactl list short sinks/sources').
# Example below: a generic C-Media USB sound fob (Digirig/DE-19 style interface).
PA_SINK=alsa_output.usb-C-Media_Electronics_Inc._USB_Audio_Device-00.analog-stereo
PA_SOURCE=alsa_input.usb-C-Media_Electronics_Inc._USB_Audio_Device-00.mono-fallback
ALSA_CARD=Device                # ALSA card name for amixer calibration ('aplay -l')
MIXER_MIC=0                     # capture level (RX ~30-40 dB on a WSJT-X-style meter)
MIXER_SPEAKER=13                # playback level (TX drive: keep ALC in the sweet zone)

# Safety rails (hard limits enforced by the engine)
WATCHDOG_S=14                   # independent unkey watchdog; FT8 frame = 12.64 s
MAX_REPEAT=6                    # never send the same frame more than this
STATE_RETRY=5                   # calls per target before moving on
MAX_TX_PER_SESSION=60           # absolute frame budget per chaser run
DUPE_RULE=day                   # skip calls already worked today (UTC)

# Hunting etiquette (ZL2IFB FT8 Operating Guide)
SNR_FLOOR=-16                   # don't call CQs weaker than this — QRP reciprocity
CQ_MODIFIERS_OK=NA,USA,US,POTA,SOTA,IOTA,QRP   # directed-CQ modifiers we answer (plain CQ always OK; contest always skipped; CQ DX skipped unless DX Mode is armed for that session — see dashboard "DX only" toggle; add your state/region)

# Dashboard
HTTP_PORT=8074
